{
  "expo": {
    "name": "Plateforme Intelligente de Monitoring et d'Optimisation des Interventions FTTH",
    "slug": "ftth-monitor-mobile",
    "version": "1.0.0",
    "platforms": [
      "android",
      "ios"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f4f7fb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "android": {
      "package": "com.ftthmonitor.mobile",
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "bundleIdentifier": "com.ftthmonitor.mobile"
    },
    "extra": {
      "eas": {
        "projectId": "d31c1a66-bf5d-4465-b65d-f737d39861fa"
      }
    }
  }
}
