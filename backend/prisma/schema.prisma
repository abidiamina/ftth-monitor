generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id                 Int          @id @default(autoincrement())
  nom                String
  prenom             String
  email              String       @unique
  motDePasse         String
  telephone          String?
  pushToken          String?
  role               Role
  actif              Boolean      @default(true)
  mustChangePassword Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  resetToken         String?
  resetTokenExpires  DateTime?
  client             Client?
  responsable        Responsable?
  technicien         Technicien?
}

model Technicien {
  id            Int                    @id @default(autoincrement())
  utilisateurId Int                    @unique
  specialite    String?
  zone          String?
  disponible    Boolean                @default(true)
  latitude      Float?
  longitude     Float?
  interventions Intervention[]
  rapports      Rapport[]
  evidences     InterventionEvidence[]
  refus         RefusIntervention[]
  utilisateur   Utilisateur            @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model Responsable {
  id                  Int            @id @default(autoincrement())
  utilisateurId       Int            @unique
  interventionsCreees Intervention[] @relation("InterventionResponsable")
  utilisateur         Utilisateur    @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model Client {
  id            Int            @id @default(autoincrement())
  utilisateurId Int            @unique
  adresse       String
  createdAt     DateTime       @default(now())
  utilisateur   Utilisateur    @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  interventions Intervention[]
}

model Intervention {
  id                    Int                    @id @default(autoincrement())
  titre                 String
  description           String
  adresse               String
  latitude              Float?
  longitude             Float?
  statut                StatutIntervention     @default(EN_ATTENTE)
  priorite              Priorite               @default(NORMALE)
  dateCreation          DateTime               @default(now())
  datePlanifiee         DateTime?
  dateDebut             DateTime?
  dateFin               DateTime?
  validee               Boolean                @default(false)
  dateValidation        DateTime?
  gpsConfirmedAt        DateTime?
  gpsLatitude           Float?
  gpsLongitude          Float?
  qrCodeValue           String?
  qrVerifiedAt          DateTime?
  clientSignature       String?
  clientSignatureAt     DateTime?
  clientSignatureBy     String?
  clientFeedbackRating  Int?
  clientFeedbackComment String?
  clientFeedbackSentiment String?
  clientFeedbackAt      DateTime?
  updatedAt             DateTime               @updatedAt
  clientId              Int
  technicienId          Int?
  responsableId         Int
  client                Client                 @relation(fields: [clientId], references: [id])
  responsable           Responsable            @relation("InterventionResponsable", fields: [responsableId], references: [id])
  technicien            Technicien?            @relation(fields: [technicienId], references: [id])
  notifications         Notification[]
  rapport               Rapport?
  evidences             InterventionEvidence[]
  refus                 RefusIntervention[]
}

model RefusIntervention {
  id             Int          @id @default(autoincrement())
  interventionId Int
  technicienId   Int
  motif          String
  createdAt      DateTime     @default(now())
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  technicien     Technicien   @relation(fields: [technicienId], references: [id], onDelete: Cascade)
}

model Rapport {
  id              Int          @id @default(autoincrement())
  interventionId  Int          @unique
  technicienId    Int
  contenu         String
  materielUtilise String?
  observations    String?
  photos          String[]
  createdAt       DateTime     @default(now())
  intervention    Intervention @relation(fields: [interventionId], references: [id])
  technicien      Technicien   @relation(fields: [technicienId], references: [id])
}

model Notification {
  id             Int           @id @default(autoincrement())
  titre          String
  message        String
  lu             Boolean       @default(false)
  createdAt      DateTime      @default(now())
  interventionId Int?
  userId         Int
  intervention   Intervention? @relation(fields: [interventionId], references: [id])
}

model InterventionEvidence {
  id             Int          @id @default(autoincrement())
  interventionId Int
  technicienId   Int?
  commentaire    String
  photoName      String
  photoData      String?
  createdAt      DateTime     @default(now())
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  technicien     Technicien?  @relation(fields: [technicienId], references: [id])
}

model Configuration {
  id          Int      @id @default(autoincrement())
  cle         String   @unique
  valeur      String
  libelle     String
  description String?
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entite    String
  entiteId  Int?
  details   String?
  userId    Int
  userEmail String
  userRole  String
  ip        String?
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  CLIENT
  RESPONSABLE
  TECHNICIEN
}

enum StatutIntervention {
  EN_ATTENTE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum Priorite {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}
