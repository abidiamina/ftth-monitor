      "item": [
        {
          "name": "POST Register Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register client status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('clientToken', data.token);",
                  "pm.collectionVariables.set('clientUserId', data.user.id);",
                  "pm.collectionVariables.set('clientEmail', data.user.email);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Ben Sassi\",\n  \"prenom\": \"Sami\",\n  \"email\": \"{{clientEmail}}\",\n  \"telephone\": \"+21612345678\",\n  \"adresse\": \"40 ali belhouane jendouba\",\n  \"motDePasse\": \"{{clientPassword}}\"\n}"
            },
